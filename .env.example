# PostgreSQL
POSTGRES_PASSWORD=changeme_development
DATABASE_URL=postgresql://shr_user:changeme_development@postgres:5432/shr_db

# Redis
REDIS_PASSWORD=changeme_redis
REDIS_URL=redis://:changeme_redis@redis:6379

# Vision service (internal Docker network)
VISION_SERVICE_URL=http://vision-service:8001

# OCR provider: 'google_vision' | 'tesseract'
# If GOOGLE_APPLICATION_CREDENTIALS not present, auto-falls back to tesseract
OCR_PROVIDER=google_vision
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google-vision.json

# Storage
STORAGE_PATH=/app/storage
STORAGE_BASE_URL=https://yourdomain.com/storage

# Security — generate with: openssl rand -hex 32
API_KEY=replace_with_64_char_random_string

# NestJS
PORT=3000
NODE_ENV=production
